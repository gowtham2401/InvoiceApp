<UserControl
    x:Class="InvoiceApp.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock
                Margin="0,0,0,20"
                Style="{StaticResource SectionTitle}"
                Text="Dashboard Overview" />

            <!--  Stat Cards Row 1  -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="#1E3A5F"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="&#x1F4B0;  Total Revenue" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TotalRevenue, StringFormat='Rs.{0:N2}'}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="All paid invoices" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="#27AE60"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="This Month" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding MonthRevenue, StringFormat='Rs.{0:N2}'}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Current month revenue" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="#F39C12"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Pending" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding PendingCount}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Awaiting payment" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Background="#2A5298"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Paid" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding PaidCount}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Completed invoices" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Stat Cards Row 2  -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="#E74C3C"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Overdue" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding OverdueCount}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Requires action" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="#7F8C8D"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Draft" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding DraftCount}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Not yet sent" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="#8E44AD"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Customers" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TotalCustomers}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="Total registered" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Background="#16A085"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#80FFFFFF"
                            Text="Total Invoices" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TotalInvoices}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="#60FFFFFF"
                            Text="All time" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Monthly Revenue Chart  -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryBrush}"
                        Text="Revenue - Last 6 Months" />
                    <ItemsControl Height="160" ItemsSource="{Binding MonthlyStats}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            HorizontalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding Total, StringFormat='Rs.{0:N0}'}" />
                                        <Border
                                            Height="80"
                                            MinHeight="4"
                                            Margin="8,0"
                                            HorizontalAlignment="Stretch"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="3,3,0,0" />
                                    </StackPanel>
                                    <Border
                                        Grid.Row="1"
                                        Height="2"
                                        Background="{StaticResource BorderBrush}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#092040"
                                        Text="{Binding Month}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
