<UserControl
    x:Class="InvoiceApp.Views.InvoiceEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:InvoiceApp.Helpers"
    Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <helpers:CurrencyConverter x:Key="Currency" />
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!--  Left: Items section  -->
        <Border Margin="0,0,12,0" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Invoice header info  -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Invoice Number" />
                        <TextBox
                            Height="34"
                            Background="#F5F5F5"
                            IsReadOnly="True"
                            Text="{Binding EditorInvoiceNumber, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <Label Content="Invoice Date" />
                        <DatePicker Height="34" SelectedDate="{Binding EditorDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Status" />
                        <ComboBox
                            Height="34"
                            ItemsSource="{Binding EditorStatusOptions}"
                            SelectedItem="{Binding EditorStatus}" />
                    </StackPanel>
                </Grid>

                <!--  Customer  -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <Label Content="Customer *" />
                    <ComboBox
                        Height="34"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Customers}"
                        SelectedItem="{Binding EditorCustomer}" />
                </StackPanel>

                <!--  Items Title  -->
                <TextBlock
                    Grid.Row="2"
                    Margin="0,0,0,8"
                    VerticalAlignment="Top"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PrimaryBrush}"
                    Text="Invoice Items" />

                <!--  Items DataGrid  -->
                <DataGrid
                    Grid.Row="2"
                    Margin="0,28,0,0"
                    CanUserAddRows="False"
                    IsReadOnly="False"
                    ItemsSource="{Binding EditorItems}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Foreground="#092040"
                            Width="*"
                            Binding="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                            Header="Item Name" />
                        <DataGridTextColumn
                            Foreground="#092040"
                            Width="60"
                            Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                            Header="Qty" />
                        <DataGridTextColumn
                            Foreground="#092040"
                            Width="100"
                            Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                            Header="Unit Price" />
                        <DataGridTextColumn
                            Foreground="#092040"
                            Width="100"
                            Binding="{Binding Total, StringFormat='Rs. {0:N2}'}"
                            Header="Total"
                            IsReadOnly="True" />
                        <DataGridTemplateColumn Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button
                                        Padding="6,2"
                                        Background="#E74C3C"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="X"
                                        FontWeight="Bold"
                                        Foreground="White" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Add New Item Row  -->
                <Border
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="10,8"
                    Background="#EEF4FF"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Height="42"
                            Margin="0,0,6,0"
                            Padding="6,4"
                            Tag="Item description..."
                            Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Grid.Column="1"
                            Height="42"
                            Margin="0,0,6,0"
                            Padding="6,4"
                            Text="{Binding NewItemQty, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Grid.Column="2"
                            Height="42"
                            Margin="0,0,6,0"
                            Padding="6,4"
                            Text="{Binding NewItemPrice, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Grid.Column="3"
                            Height="42"
                            Padding="12,0"
                            Command="{Binding AddItemCommand}"
                            Content="Add Item"
                            Style="{StaticResource PrimaryButton}" />
                    </Grid>
                </Border>

                <!--  Tax  -->
                <Grid Grid.Row="4" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Content="Tax (%)" />
                    <TextBox
                        Grid.Column="1"
                        Height="32"
                        Margin="4,0,0,0"
                        Padding="6,4"
                        Text="{Binding EditorTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Subtotal: " />
                        <TextBlock FontWeight="SemiBold" Text="{Binding EditorSubtotal, Converter={StaticResource Currency}}" />
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="   Tax: " />
                        <TextBlock FontWeight="SemiBold" Text="{Binding EditorTaxAmount, Converter={StaticResource Currency}}" />
                        <TextBlock
                            FontWeight="Bold"
                            Foreground="{StaticResource PrimaryBrush}"
                            Text="   Grand Total: " />
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{StaticResource PrimaryBrush}"
                            Text="{Binding EditorGrandTotal, Converter={StaticResource Currency}}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!--  Right: Notes + Actions  -->
        <Border Grid.Column="1" Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PrimaryBrush}"
                    Text="Notes" />
                <TextBox
                    Height="120"
                    Margin="0,0,0,20"
                    AcceptsReturn="True"
                    Text="{Binding EditorNotes, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />

                <!--  Totals Summary  -->
                <Border
                    Margin="0,0,0,20"
                    Padding="14"
                    Background="#F8FAFD"
                    CornerRadius="6">
                    <StackPanel>
                        <DockPanel Margin="0,4">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Subtotal" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontWeight="SemiBold"
                                Text="{Binding EditorSubtotal, Converter={StaticResource Currency}}" />
                        </DockPanel>
                        <DockPanel Margin="0,4">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding EditorTaxPercent, StringFormat='Tax ({0}%)'}" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontWeight="SemiBold"
                                Text="{Binding EditorTaxAmount, Converter={StaticResource Currency}}" />
                        </DockPanel>
                        <Separator Margin="0,8" />
                        <DockPanel Margin="0,4">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontWeight="Bold"
                                Foreground="{StaticResource PrimaryBrush}"
                                Text="GRAND TOTAL" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{StaticResource PrimaryBrush}"
                                Text="{Binding EditorGrandTotal, Converter={StaticResource Currency}}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  Action Buttons  -->
                <Button
                    Height="40"
                    Margin="0,0,0,8"
                    Command="{Binding SaveInvoiceCommand}"
                    Content="Save Invoice"
                    Style="{StaticResource SuccessButton}" />
                <Button
                    Height="36"
                    Command="{Binding CancelEditCommand}"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
