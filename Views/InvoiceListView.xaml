<UserControl
    x:Class="InvoiceApp.Views.InvoiceListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:InvoiceApp.Helpers"
    Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <helpers:StatusToBrushConverter x:Key="StatusToBrush" />
        <helpers:CurrencyConverter x:Key="Currency" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
    </UserControl.Resources>
    <Grid>
        <!--  Invoice Editor Overlay  -->
        <ContentControl Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <views:InvoiceEditorView xmlns:views="clr-namespace:InvoiceApp.Views" DataContext="{Binding}" />
        </ContentControl>

        <!--  Invoice List  -->
        <Grid Margin="20" Visibility="{Binding IsEditing, Converter={StaticResource InvBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock
                    DockPanel.Dock="Left"
                    Style="{StaticResource SectionTitle}"
                    Text="Invoices" />
                <Button
                    Command="{Binding NewInvoiceCommand}"
                    Content="+ New Invoice"
                    DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButton}" />
            </DockPanel>

            <!--  Filters  -->
            <Border
                Grid.Row="1"
                Margin="0,0,0,12"
                Padding="14,10"
                Style="{StaticResource CardPanel}">
                <WrapPanel>
                    <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                        <Label VerticalAlignment="Center" Content="Search:" />
                        <TextBox
                            Width="180"
                            Height="50"
                            Style="{StaticResource SearchBox}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                        <Label VerticalAlignment="Center" Content="Status: " />
                        <ComboBox
                            Width="110"
                            Height="25"
                            ItemsSource="{Binding StatusOptions}"
                            SelectedItem="{Binding StatusFilter}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                        <Label VerticalAlignment="Center" Content="From: " />
                        <DatePicker
                            Width="130"
                            Height="25"
                            SelectedDate="{Binding FromDate}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                        <Label VerticalAlignment="Center" Content="To: " />
                        <DatePicker
                            Width="130"
                            Height="25"
                            SelectedDate="{Binding ToDate}" />
                    </StackPanel>
                    <Button
                        Height="25"
                        Padding="12,0"
                        Command="{Binding ClearFiltersCommand}"
                        Content="Clear"
                        Style="{StaticResource SecondaryButton}" />
                </WrapPanel>
            </Border>

            <!--  DataGrid  -->
            <Border
                Grid.Row="2"
                Padding="0"
                Style="{StaticResource CardPanel}">
                <DataGrid
                    Padding="0"
                    BorderThickness="0"
                    ItemsSource="{Binding FilteredInvoices}"
                    SelectedItem="{Binding SelectedInvoice}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding InvoiceNumber}"
                            Foreground="#092040"
                            Header="Invoice #" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding Date, StringFormat='dd MMM yyyy'}"
                            Foreground="#092040"
                            Header="Date" />
                        <DataGridTemplateColumn Width="*" Header="Customer">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Padding="8,4"
                                        Foreground="#092040"
                                        Text="{Binding CustomerId}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding GrandTotal, StringFormat='Rs. {0:N2}'}"
                            Foreground="#092040"
                            Header="Grand Total" />
                        <DataGridTemplateColumn Width="100" Header="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="4,2"
                                        Padding="8,2"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                        CornerRadius="10">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Status}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--  Action Buttons  -->
            <StackPanel
                Grid.Row="3"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding EditInvoiceCommand}"
                    Content="Edit Invoice"
                    Style="{StaticResource SecondaryButton}" />
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding ExportPdfCommand}"
                    Content="Export PDF"
                    Style="{StaticResource SuccessButton}" />
                <Button
                    Command="{Binding DeleteInvoiceCommand}"
                    Content="Delete"
                    Style="{StaticResource DangerButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
