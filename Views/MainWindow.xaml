<Window x:Class="InvoiceApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:InvoiceApp.Views"
        Title="Invoice Generator Pro" Height="750" Width="1200"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Background="{StaticResource PrimaryBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="54">
                    <TextBlock Foreground="White" Text="📄" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Invoice Generator Pro" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Professional Invoice Management"
                               FontSize="12" Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="4,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="⟳ Refresh" Style="{StaticResource SecondaryButton}"
                        Foreground="White" BorderBrush="#40FFFFFF"
                        Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="📊  Dashboard" Style="{StaticResource NavTab}">
                <views:DashboardView DataContext="{Binding DashboardVM}"/>
            </TabItem>
            <TabItem Header="👥  Customers" Style="{StaticResource NavTab}">
                <views:CustomersView DataContext="{Binding CustomerVM}"/>
            </TabItem>
            <TabItem Header="📋  Invoices" Style="{StaticResource NavTab}">
                <views:InvoiceListView DataContext="{Binding InvoiceVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
